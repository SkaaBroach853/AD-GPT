<resources>
    <style name="Theme.ADGPT" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">@color/adgpt_black</item>
        <item name="android:colorAccent">@color/adgpt_black</item>
    </style>

    <style name="Theme.ADGPT.Startup" parent="Theme.ADGPT">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:navigationBarColor">@color/adgpt_black</item>
        <item name="android:statusBarColor">@color/adgpt_black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
